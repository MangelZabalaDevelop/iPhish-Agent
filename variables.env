# Set environment variables in the format KEY=VALUE, 1 per line
# This file will be sourced inside the project container when started.
# NOTE: If you change this file while the project is running, you must restart the project container for changes to take effect.
HERMES_MODEL=Qwen3.6-35B-A3B-NVFP4
HERMES_BASE_URL=http://192.168.0.8:9494
HERMES_API_KEY=local-external-vllm-placeholder
HERMES_API_SERVER_KEY=local-hermes-agent
HERMES_IMAGE=nousresearch/hermes-agent:latest
HERMES_CONTAINER_NAME=xpectra-iphish-agent
GOPHISH_IMAGE=xpectra/gophish-arm64:v0.12.1
GOPHISH_CONTAINER_NAME=xpectra-iphish-agent-gophish
GOPHISH_API_KEY=local-gophish-api-key-change-me
GOPHISH_ADMIN_URL=http://127.0.0.1:3333
GOPHISH_API_URL=http://127.0.0.1:3333/api
GOPHISH_PUBLIC_URL=http://127.0.0.1:8080
